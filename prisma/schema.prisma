generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

model User {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(100)
  password   String
  role       Role     @default(EMPLOYEE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Customer {
  id                  Int      @id @default(autoincrement())
  cpf                 String   @unique @db.VarChar(14)
  name                String   @db.VarChar(100)
  email               String   @unique @db.VarChar(100)
  phone_number        String?  @db.VarChar(20)
  flight_hour_balance Int      @default(0)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  instructors Instructor[]
  partners    Partner[]
  students    Student[]
  flights     Flight[]
  invoices    Invoice[]
  receivables Receivable[]

  @@map("customer")
}

model Instructor {
  id          Int      @id @default(autoincrement())
  canac       String   @unique @db.VarChar(20)
  cht         Int?
  customer_id Int
  customer    Customer @relation(fields: [customer_id], references: [id])

  flights  Flight[]
  payables Payable[]

  @@map("instructors")
}

model Partner {
  id                Int       @id @default(autoincrement())
  customer_id       Int
  monthly_dues      Decimal   @db.Decimal(10, 2)
  next_due_date     DateTime? @db.Date
  last_payment_date DateTime? @db.Date
  status            String    @default("active") @db.VarChar(20)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  customer Customer @relation(fields: [customer_id], references: [id])

  @@map("partners")
}

model Student {
  id                           Int     @id @default(autoincrement())
  customer_id                  Int
  voter_registration           String? @db.VarChar(20)
  military_service_certificate String? @db.VarChar(30)
  canac                        String? @db.VarChar(20)

  customer Customer @relation(fields: [customer_id], references: [id])

  @@map("student")
}

model Plane {
  id                Int     @id @default(autoincrement())
  registration      String  @unique @db.VarChar(10)
  model             String? @db.VarChar(60)
  flight_hour_value Decimal @db.Decimal(10, 2)
  status            String  @default("active") @db.VarChar(20)

  flights Flight[]

  @@map("planes")
}

model Flight {
  id             Int       @id @default(autoincrement())
  plane_id       Int
  customer_id    Int
  instructor_id  Int?
  type           String    @db.VarChar(30)
  double_command Boolean   @default(false)
  status         String    @default("in-flight") @db.VarChar(20)
  origin         String    @db.VarChar(10)
  destination    String    @db.VarChar(10)
  start_date     DateTime
  end_date       DateTime?
  total_hours    Decimal?  @db.Decimal(6, 2)
  total_amount   Decimal?  @db.Decimal(10, 2)

  plane      Plane       @relation(fields: [plane_id], references: [id])
  customer   Customer    @relation(fields: [customer_id], references: [id])
  instructor Instructor? @relation(fields: [instructor_id], references: [id])

  receivables Receivable[]

  @@map("flights")
}

model Invoice {
  id           Int       @id @default(autoincrement())
  customer_id  Int
  total_amount Decimal   @default(0) @db.Decimal(10, 2)
  status       String    @default("open") @db.VarChar(20)
  issue_date   DateTime  @default(now()) @db.Date
  due_date     DateTime? @db.Date
  paid_at      DateTime?
  created_at   DateTime  @default(now())

  customer            Customer            @relation(fields: [customer_id], references: [id])
  receivables         Receivable[]
  receivable_payments ReceivablePayment[]

  @@map("invoices")
}

model Receivable {
  id              Int      @id @default(autoincrement())
  client_id       Int?
  flight_id       Int?
  invoice_id      Int?
  title           String   @db.VarChar(100)
  description     String?
  expiration_date DateTime @db.Date
  total_amount    Decimal  @db.Decimal(10, 2)
  amount_received Decimal  @default(0) @db.Decimal(10, 2)
  product         String?  @db.VarChar(50)
  status          Int      @default(0) @db.SmallInt
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  customer Customer? @relation(fields: [client_id], references: [id])
  flight   Flight?   @relation(fields: [flight_id], references: [id])
  invoice  Invoice?  @relation(fields: [invoice_id], references: [id])
  payments ReceivablePayment[]

  @@map("receivables")
}

model ReceivablePayment {
  id              Int      @id @default(autoincrement())
  receivable_id   Int
  invoice_id      Int?
  amount_received Decimal  @db.Decimal(10, 2)
  payment_method  String?  @db.VarChar(30)
  payment_date    DateTime @default(now())
  notes           String?

  receivable Receivable @relation(fields: [receivable_id], references: [id])
  invoice    Invoice?   @relation(fields: [invoice_id], references: [id])

  @@map("receivable_payments")
}

model Payable {
  id                 Int       @id @default(autoincrement())
  instructor_id      Int
  title              String    @db.VarChar(100)
  description        String?
  total_amount       Decimal   @db.Decimal(10, 2)
  installments_count Int       @default(1)
  status             String    @default("open") @db.VarChar(20)
  expiration_date    DateTime? @db.Date
  product            String?   @db.VarChar(50)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  instructor   Instructor          @relation(fields: [instructor_id], references: [id])
  installments PayableInstallment[]

  @@map("payables")
}

model PayableInstallment {
  id                 Int      @id @default(autoincrement())
  payable_id         Int
  installment_number Int
  amount             Decimal  @db.Decimal(10, 2)
  amount_paid        Decimal  @default(0) @db.Decimal(10, 2)
  expiration_date    DateTime @db.Date
  status             String   @default("open") @db.VarChar(20)

  payable Payable @relation(fields: [payable_id], references: [id])

  @@map("payable_installments")
}
