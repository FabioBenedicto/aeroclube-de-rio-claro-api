generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

model Settings {
  id                     Int     @id @default(1)
  instructor_percentage  Decimal @db.Decimal(5, 2)
  partner_monthly_dues   Decimal @db.Decimal(10, 2)
  glider_initial_minutes Int     @default(45)
  glider_initial_value   Decimal @default(330) @db.Decimal(10, 2)
  glider_minute_value    Decimal @default(3) @db.Decimal(10, 2)

  sicoob_cooperativa_prefix String? @db.VarChar(5)
  sicoob_cooperativa_dv     String? @db.VarChar(1)
  sicoob_agencia            String? @db.VarChar(4)
  sicoob_conta              String? @db.VarChar(12)
  sicoob_conta_dv           String? @db.VarChar(1)
  sicoob_carteira           String? @db.VarChar(1)
  sicoob_modalidade         String? @db.VarChar(2)
  sicoob_cnpj               String? @db.VarChar(14)
  sicoob_nome_empresa       String? @db.VarChar(30)
  sicoob_remessa_sequence   Int     @default(0)
  sicoob_juros              Decimal @default(0) @db.Decimal(5, 2)
  sicoob_juros_prazo        Int     @default(0)
  sicoob_juros_tipo         String  @default("2") @db.VarChar(1)

  @@map("settings")
}

model User {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(100)
  password   String
  role       Role     @default(EMPLOYEE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  permissions UserPermission[]

  @@map("users")
}

model Person {
  id                  Int      @id @default(autoincrement())
  cpf                 String   @unique @db.VarChar(14)
  name                String   @db.VarChar(100)
  email               String   @unique @db.VarChar(100)
  phone_number        String?  @db.VarChar(20)
  flight_hour_balance Int      @default(0)
  credit_balance      Decimal  @default(0) @db.Decimal(10, 2)
  address             String?  @db.VarChar(40)
  neighborhood        String?  @db.VarChar(50)
  city                String?  @db.VarChar(50)
  state               String?  @db.VarChar(2)
  zip_code            String?  @db.VarChar(8)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  instructors Instructor[]
  partners    Partner[]
  students    Student[]
  employees   Employee[]
  flights     Flight[]
  bills       Bill[]
  receivables Receivable[]
  payables    Payable[]

  @@map("peoples")
}

model Instructor {
  id          Int      @id @default(autoincrement())
  customer_id Int
  customer    Person   @relation(fields: [customer_id], references: [id])

  flights     Flight[]
  payables    Payable[]
  receivables Receivable[]

  @@map("instructors")
}

model Partner {
  id                Int       @id @default(autoincrement())
  customer_id       Int
  monthly_dues      Decimal   @db.Decimal(10, 2)
  next_due_date     DateTime? @db.Date
  last_payment_date DateTime? @db.Date
  status            String    @default("active") @db.VarChar(20)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  customer     Person       @relation(fields: [customer_id], references: [id])
  receivables  Receivable[]
  payables     Payable[]

  @@map("partners")
}

model Student {
  id          Int      @id @default(autoincrement())
  customer_id Int

  customer Person   @relation(fields: [customer_id], references: [id])

  @@map("student")
}

model Employee {
  id          Int      @id @default(autoincrement())
  customer_id Int

  customer     Person       @relation(fields: [customer_id], references: [id])
  receivables  Receivable[]
  payables     Payable[]

  @@map("employees")
}

model Plane {
  id                Int      @id @default(autoincrement())
  registration      String   @unique @db.VarChar(10)
  model             String?  @db.VarChar(60)
  aircraft_type     String   @default("airplane") @db.VarChar(10)
  flight_hour_value Decimal? @db.Decimal(10, 2)
  created_at        DateTime @default(now())

  flights     Flight[]
  receivables Receivable[]
  payables    Payable[]

  @@map("planes")
}

model Flight {
  id                    Int       @id @default(autoincrement())
  plane_id              Int
  customer_id           Int
  instructor_id         Int?
  aircraft_type         String    @default("airplane") @db.VarChar(10)
  type                  String    @db.VarChar(30)
  double_command        Boolean   @default(false)
  origin                String    @db.VarChar(10)
  destination           String    @db.VarChar(10)
  start_date            DateTime
  end_date              DateTime?
  total_hours           Decimal?  @db.Decimal(6, 2)
  total_amount          Decimal?  @db.Decimal(10, 2)
  calculation_breakdown Json?

  plane      Plane       @relation(fields: [plane_id], references: [id])
  customer   Person      @relation(fields: [customer_id], references: [id])
  instructor Instructor? @relation(fields: [instructor_id], references: [id])

  receivables Receivable[]

  @@map("flights")
}

enum BillStatus {
  open
  pending_cnab
  paid
  cancelled
}

model Bill {
  id               Int        @id @default(autoincrement())
  customer_id      Int
  total_amount     Decimal    @default(0) @db.Decimal(10, 2)
  issue_date       DateTime   @default(now()) @db.Date
  due_date         DateTime?  @db.Date
  paid_at          DateTime?
  status           BillStatus @default(open)
  payment_source   String?    @db.VarChar(10)
  payment_method   String?    @db.VarChar(30)
  created_at       DateTime   @default(now())
  nota_fiscal_path String?

  customer            Person              @relation(fields: [customer_id], references: [id])
  receivable_payments ReceivablePayment[]

  @@map("bills")
}

model Company {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  cnpj       String?  @unique @db.VarChar(18)
  email      String?  @db.VarChar(100)
  phone      String?  @db.VarChar(20)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  receivables Receivable[]
  payables    Payable[]

  @@map("companies")
}

enum PayerType {
  customer
  company
  instructor
  partner
  employee
  none
}

model Receivable {
  id              Int       @id @default(autoincrement())
  client_id       Int?
  company_id      Int?
  flight_id       Int?
  instructor_id   Int?
  plane_id        Int?
  partner_id      Int?
  employee_id     Int?
  payer_type      PayerType @default(none)
  title           String    @db.VarChar(100)
  description     String?
  expiration_date DateTime? @db.Date
  total_amount    Decimal   @db.Decimal(10, 2)
  amount_received Decimal   @default(0) @db.Decimal(10, 2)
  product         String?   @db.VarChar(50)
  status          Int       @default(0) @db.SmallInt
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  customer   Person?     @relation(fields: [client_id], references: [id])
  company    Company?    @relation(fields: [company_id], references: [id])
  flight     Flight?     @relation(fields: [flight_id], references: [id], onDelete: Cascade)
  instructor Instructor? @relation(fields: [instructor_id], references: [id])
  plane      Plane?      @relation(fields: [plane_id], references: [id])
  partner    Partner?    @relation(fields: [partner_id], references: [id])
  employee   Employee?   @relation(fields: [employee_id], references: [id])
  payments   ReceivablePayment[]

  @@map("receivables")
}

model ReceivablePayment {
  id               Int      @id @default(autoincrement())
  receivable_id    Int
  bill_id          Int?
  amount_received  Decimal  @db.Decimal(10, 2)
  payment_method   String?  @db.VarChar(30)
  payment_date     DateTime @default(now())
  nota_fiscal_path String?

  receivable Receivable @relation(fields: [receivable_id], references: [id], onDelete: Cascade)
  bill       Bill?      @relation(fields: [bill_id], references: [id])

  @@map("receivable_payments")
}

model Payable {
  id            Int       @id @default(autoincrement())
  client_id     Int?
  company_id    Int?
  instructor_id Int?
  plane_id      Int?
  partner_id    Int?
  employee_id   Int?
  payer_type    PayerType @default(none)
  title         String    @db.VarChar(100)
  description   String?
  amount        Decimal   @db.Decimal(10, 2)
  amount_paid   Decimal   @default(0) @db.Decimal(10, 2)
  status        String    @default("open") @db.VarChar(20)
  due_date      DateTime? @db.Date
  product       String?   @db.VarChar(50)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  customer   Person?        @relation(fields: [client_id], references: [id])
  company    Company?       @relation(fields: [company_id], references: [id])
  instructor Instructor?    @relation(fields: [instructor_id], references: [id])
  plane      Plane?         @relation(fields: [plane_id], references: [id])
  partner    Partner?       @relation(fields: [partner_id], references: [id])
  employee   Employee?      @relation(fields: [employee_id], references: [id])
  payments   PayablePayment[]

  @@map("payables")
}

model PayablePayment {
  id               Int      @id @default(autoincrement())
  payable_id       Int
  amount           Decimal  @db.Decimal(10, 2)
  method           String?  @db.VarChar(30)
  paid_at          DateTime @default(now())
  notes            String?
  nota_fiscal_path String?

  payable Payable @relation(fields: [payable_id], references: [id], onDelete: Cascade)

  @@map("payable_payments")
}

model UserPermission {
  id         Int    @id @default(autoincrement())
  user_id    Int
  permission String @db.VarChar(50)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, permission])
  @@map("user_permissions")
}

model CnabRemessa {
  id              Int      @id @default(autoincrement())
  created_at      DateTime @default(now())
  sequence_number Int
  bill_ids        Json
  bill_count      Int
  total_amount    Decimal  @db.Decimal(12, 2)
  file_path       String   @db.VarChar(200)

  @@map("cnab_remessas")
}

model CnabRetorno {
  id             Int      @id @default(autoincrement())
  processed_at   DateTime @default(now())
  paid_ids       Json
  rejected_ids   Json
  errors         Json
  paid_count     Int
  rejected_count Int

  @@map("cnab_retornos")
}
